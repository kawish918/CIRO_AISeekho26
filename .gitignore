# Python Virtual Environment
venv/
.venv/
env/
ENV/

# Python caches and compiled files
**/__pycache__/
**/*.py[cod]
**/*.$py.class
**/.pytest_cache/

# Node dependencies (the biggest source of massive small files)
**/node_modules/

# Expo / React Native cache & builds
**/.expo/
**/dist/
**/web-build/
**/expo-env.d.ts
**/.metro-health-check*
**/ios/
**/android/

# Native keys and provisions
**/*.jks
**/*.p8
**/*.p12
**/*.key
**/*.mobileprovision

# Environment files (never commit secrets/API keys to GitHub)
**/.env
**/.env.local
**/.env*.local

# Cache and logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# OS files
**/.DS_Store
Thumbs.db

# Project notes (optional: uncomment if you want to keep them local, or leave commented to push them)
# /plan.txt
# /working.txt
# /langgraph.txt
